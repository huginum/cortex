{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cortex",
  "version": "0.1.0",
  "identifier": "com.huginum.cortex",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cortex",
        "width": 1200,
        "height": 820,
        "minWidth": 720,
        "minHeight": 520
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "license": "Apache-2.0",
    "resources": ["agent-bin/*"],
    "macOS": {
      "entitlements": "Entitlements.plist"
    },
    "linux": {
      "appimage": {
        "files": {
          "usr/lib/libkrun.so.1": "appimage-libs/libkrun.so.1",
          "usr/lib/libkrunfw.so.5": "appimage-libs/libkrunfw.so.5"
        }
      }
    }
  }
}
