<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required to create and run microVMs via Hypervisor.framework (libkrun). -->
    <key>com.apple.security.hypervisor</key>
    <true/>
    <!-- libkrun and libkrunfw are third-party dylibs (Homebrew), not signed by
         this app's team; allow loading them under the hardened runtime. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
